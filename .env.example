# Windscribe Website Authentication
# Set WS_SESSION_COOKIE to your ws_session_auth_hash cookie value from the browser
# 1. Log into Windscribe manually in your browser
# 2. Export cookies using a browser extension (EditThisCookie/Cookie-Editor)
# 3. Find the "ws_session_auth_hash" cookie and copy its value

WS_SESSION_COOKIE=your_ws_session_auth_hash_value

# Windscribe VPN Credentials (for Gluetun/OpenVPN connection)
# These are DIFFERENT from your website login credentials
OPENVPN_USER=your_vpn_username
OPENVPN_PASSWORD=your_vpn_password
SERVER_CITIES=Brussels

# qBittorrent (Required for full test)
QBIT_HOST=localhost
QBIT_PORT=8080
QBIT_USERNAME=default123!!
QBIT_PASSWORD=default123!!
QBIT_PRIVATE_TRACKER=false

# Gluetun (Required for full test)
GLUETUN_HOST=localhost
GLUETUN_PORT=8000
GLUETUN_AUTH_TYPE=none
GLUETUN_USERNAME=
GLUETUN_PASSWORD=
GLUETUN_API_KEY=

# Schedule
ONESHOT=true
DAYS=6
TIME=02:00
REQUEST_TIMEOUT=5
